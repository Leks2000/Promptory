{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.1.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "identity",
    "contextMenus",
    "notifications",
    "clipboardWrite",
    "tabs"
  ],
  "host_permissions": [
    "https://vofgfvlgchqheksvlibl.supabase.co/*",
    "*://chat.openai.com/*",
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://perplexity.ai/*",
    "*://poe.com/*",
    "*://you.com/*",
    "*://bard.google.com/*",
    "*://copilot.microsoft.com/*",
    "*://bing.com/*",
    "*://pi.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://perplexity.ai/*",
        "*://poe.com/*",
        "*://you.com/*",
        "*://bard.google.com/*",
        "*://copilot.microsoft.com/*",
        "*://bing.com/*",
        "*://pi.ai/*",
        "<all_urls>"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "commands": {
    "open-search": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "MacCtrl+Shift+P"
      },
      "description": "Open prompt search overlay"
    },
    "hotkey-1": {
      "suggested_key": {
        "default": "Alt+1",
        "mac": "Alt+1"
      },
      "description": "Insert prompt from slot 1"
    },
    "hotkey-2": {
      "suggested_key": {
        "default": "Alt+2",
        "mac": "Alt+2"
      },
      "description": "Insert prompt from slot 2"
    },
    "hotkey-3": {
      "suggested_key": {
        "default": "Alt+3",
        "mac": "Alt+3"
      },
      "description": "Insert prompt from slot 3"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["_locales/*/messages.json", "auth-callback.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
